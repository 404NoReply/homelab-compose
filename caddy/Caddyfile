# TinyAuth Forwarder Snippet
# This reusable snippet defines the forward authentication configuration for TinyAuth
# It ensures all incoming requests are authenticated via the TinyAuth service before being proxied
(tinyauth_forwarder) {
    forward_auth tinyauth:3000 {
        uri /api/auth/caddy
    }
}

# Example: Enable TinyAuth for a Service
# This example protects the Beszel service with TinyAuth
beszel.example-domain.com {
    import tinyauth_forwarder
    reverse_proxy beszel:8090
}

# Example: Custom SSL/TLS Certificates
# Use this example if you have your own SSL certificates
beszel.example-domain.com {
    tls /certs/certificate.pem /certs/key.pem
    reverse_proxy beszel:8090
}

# Example: Basic Reverse Proxy
# This example shows a simple reverse proxy
beszel.example-domain.com {
    reverse_proxy beszel:8090
}